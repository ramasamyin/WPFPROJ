<Window x:Class="Wordle_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wordle_App" xmlns:viewmodel="clr-namespace:Wordle_App.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:CellViewModel}"
        mc:Ignorable="d"
        Title="Wordle" Height="800" Width="800" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="WORDLE" FontFamily="Calibri" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Margin="20,10,10,0"/>
        <!-- GRID -->
        <ItemsControl ItemsSource="{Binding Cells}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="300"
                  Height="360"
                  Grid.Row="1" Margin="30">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="6" Columns="5"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1"
                        BorderBrush="Black"
                        Background="{Binding Color}"
                        Margin="5"
                        CornerRadius="5">
                        
                        <TextBlock Text="{Binding Value}"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>

        <!-- KEYBOARD -->
        <UniformGrid Grid.Row="2" Rows="3" Columns="10" Margin="10" VerticalAlignment="Center" Height="150" Width="450" HorizontalAlignment="Center">
                <UniformGrid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </UniformGrid.Resources>

                <Button Content="Q" Command="{Binding KeyCommand}" CommandParameter="Q"/>
            <Button Content="W" Command="{Binding KeyCommand}" CommandParameter="W"/>
            <Button Content="E" Command="{Binding KeyCommand}" CommandParameter="E"/>
            <Button Content="R" Command="{Binding KeyCommand}" CommandParameter="R"/>
            <Button Content="T" Command="{Binding KeyCommand}" CommandParameter="T"/>
            <Button Content="Y" Command="{Binding KeyCommand}" CommandParameter="Y"/>
            <Button Content="U" Command="{Binding KeyCommand}" CommandParameter="U"/>
            <Button Content="I" Command="{Binding KeyCommand}" CommandParameter="I"/>
            <Button Content="O" Command="{Binding KeyCommand}" CommandParameter="O"/>
            <Button Content="P" Command="{Binding KeyCommand}" CommandParameter="P"/>

            <Button Content="A" Command="{Binding KeyCommand}" CommandParameter="A"/>
            <Button Content="S" Command="{Binding KeyCommand}" CommandParameter="S"/>
            <Button Content="D" Command="{Binding KeyCommand}" CommandParameter="D"/>
            <Button Content="F" Command="{Binding KeyCommand}" CommandParameter="F"/>
            <Button Content="G" Command="{Binding KeyCommand}" CommandParameter="G"/>
            <Button Content="H" Command="{Binding KeyCommand}" CommandParameter="H"/>
            <Button Content="J" Command="{Binding KeyCommand}" CommandParameter="J"/>
            <Button Content="K" Command="{Binding KeyCommand}" CommandParameter="K"/>
            <Button Content="L" Command="{Binding KeyCommand}" CommandParameter="L"/>

            <Button Content="ENT" Background="LightGreen" Command="{Binding EnterCommand}"/>
            <Button Content="Z" Command="{Binding KeyCommand}" CommandParameter="Z"/>
            <Button Content="X" Command="{Binding KeyCommand}" CommandParameter="X"/>
            <Button Content="C" Command="{Binding KeyCommand}" CommandParameter="C"/>
            <Button Content="V" Command="{Binding KeyCommand}" CommandParameter="V"/>
            <Button Content="B" Command="{Binding KeyCommand}" CommandParameter="B"/>
            <Button Content="N" Command="{Binding KeyCommand}" CommandParameter="N"/>
            <Button Content="M" Command="{Binding KeyCommand}" CommandParameter="M"/>
            <Button Content="⌫" Background="Gray" Command="{Binding BackspaceCommand}"/>
        </UniformGrid>

    </Grid>
</Window>
