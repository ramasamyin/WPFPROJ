<Window x:Class="userdatabase.Views.AddUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:userdatabase.Views"
        mc:Ignorable="d"
        Title="AddUser" Height="450" Width="400">
    <Grid>
        <Label Content="Name" Margin="25" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <TextBox Height="30" Text="{Binding Name}" Width="200" Margin="25,50,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="#E0E0E0" Name="NameTextBox"/>

        <Label Content="Email" Margin="25,100,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <TextBox Height="30" Text="{Binding Email}" Width="200" Margin="25,150,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="#E0E0E0" Name="EmailTextBox"/>

        <Button Content="Add" Command="{Binding AddUserCommand}" Width="100" Height="30" Margin="25,220,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="#E0E0E0" />
    </Grid>
</Window>
