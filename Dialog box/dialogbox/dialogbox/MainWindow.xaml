<Window x:Class="dialogbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dialogbox"
        mc:Ignorable="d"
        Title ="Factory settings" Height="650" Width="1000" Background="White" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Background="White" >
            <TextBlock FontSize="20" Margin="15"/>
            <TextBlock Text="routes" FontSize="11" Margin="10"/>
            <TextBlock FontSize="20" Margin="15"/>
            <TextBlock Text="sheets" FontSize="11" Margin="10"/>
            <TextBlock FontSize="20" Margin="15"/>
            <TextBlock Text="users" FontSize="11" Margin="10"/>
            <TextBlock FontSize="20" Margin="15"/>
            <TextBlock Text="edit" FontSize="11" Margin="10"/>
            <TextBlock FontSize="20" Margin="15"/>
            <TextBlock Text="customers" FontSize="11" Margin="10"/>
            <TextBlock FontSize="20" Margin="15"/>
            <TextBlock Text="settings" FontSize="11" Margin="10"/>
        </StackPanel>
        <TreeView Grid.Column="1" Margin="10" Background="White" BorderThickness="0">
            <TreeViewItem Header="Settings" IsExpanded="True">
                <TreeViewItem Header="Environment"/>
                <TreeViewItem Header="Import"/>
                <TreeViewItem Header="Bend" IsExpanded="True">
                    <TreeViewItem Header="Fold"/>
                    <TreeViewItem Header="Cut"/>
                </TreeViewItem>
                <TreeViewItem Header="Notifications"/>
                <TreeViewItem Header="Watch"/>
                <TreeViewItem Header="Job"/>
                <TreeViewItem Header="Reports"/>
            </TreeViewItem>
        </TreeView>

        <StackPanel Grid.Column="2" Margin="15">
            <Border Background="#5A5A5A" Height="25">
                <TextBlock Text="Watch settings" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            <StackPanel Margin="10">
                <CheckBox Content="Enable 'Live Folder'" Margin="165,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBox Width="180" />
                    <TextBlock Text="Watch this folder" Margin="5,3"/>
                </StackPanel>
                <CheckBox Content="Watch sub-folders also" Margin="165,5"/>
            </StackPanel>
            
            <Border Background="#5A5A5A" Height="25" Margin="0,10,0,0">
                <TextBlock Text="After File Import" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal">
                    <ComboBox Width="180">
                        <ComboBoxItem Content="Move imported file"/>
                        <ComboBoxItem Content="Delete imported file"/>
                    </ComboBox>
                    <TextBlock Text="After import" Margin="10,3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBox Width="180" />
                    <TextBlock Text="Move files to this folder" Margin="10,3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="180"/>
                    <TextBlock Text="Move spreadsheets with errors to this folder" Margin="10,3"/>
                </StackPanel>
            </StackPanel>
            
            <Border Background="#5A5A5A" Height="25" Margin="0,10,0,0">
                <TextBlock Text="Spreadsheet import settings" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            <StackPanel Margin="10">
                <CheckBox Content="Import spreadsheet from 'Live Folder'" Margin="165,5"/>
                <CheckBox Content="Do not import spreadsheet with errors" Margin="165,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <ComboBox Width="180">
                        <ComboBoxItem Content="Import jobs"/>
                        <ComboBoxItem Content="Import Orders"/>
                        <ComboBoxItem Content="Import Assemblies"/>
                        <ComboBoxItem Content="Import Parts"/>
                    </ComboBox>
                    <TextBlock Text="Spreadsheet import option" Margin="5,3"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>