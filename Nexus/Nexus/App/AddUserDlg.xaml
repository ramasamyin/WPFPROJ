<Window x:Class="Nexus.App.AddUserDlg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nexus.App"
        mc:Ignorable="d"
            SizeToContent="WidthAndHeight" Style="{StaticResource DialogBase}" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label Content="ID:" IsEnabled="False" />
        <TextBox IsHitTestVisible="False" IsEnabled="False" Grid.Column="1" Text="{Binding ID, Mode=OneWay}"/>
        <Label Name="LblFName" Content="_First Name:" Grid.Row="1" Target="{Binding ElementName=TxtFName}"/>
        <TextBox x:Name="TxtFName" Grid.Row="1" Grid.Column="1" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        <Label Name="LblLName" Content="_Last Name:" Grid.Row="2" Target="{Binding ElementName=TxtLName}"/>
        <TextBox x:Name="TxtLName" Grid.Row="2" Grid.Column="1" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        <Label Name="LblAge" Content="A_ge:" Grid.Row="3" Target="{Binding ElementName=TxtAge}"/>
        <TextBox x:Name="TxtAge" Grid.Row="3" Grid.Column="1" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        <Label Name="LblEmail" Content="_Email:" Grid.Row="4" Target="{Binding ElementName=TxtEmail}"/>
        <TextBox x:Name="TxtEmail" Grid.Row="4" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        <Label Name="LblPhone" Content="_Phone:" Grid.Row="5" Target="{Binding ElementName=TxtPhone}"/>
        <TextBox x:Name="TxtPhone" Grid.Row="5" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="_OK" Name="BtnOK" IsDefault="True"/>
            <Button Content="_Cancel" Name="BtnCancel" IsCancel="True" Margin="10,0,2,0"/>
        </StackPanel>
    </Grid>
</Window>


