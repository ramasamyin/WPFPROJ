<Window x:Class="scribblepane.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:scribblepane"
        mc:Ignorable="d"
        Title="Scribble Pad" Height="500" Width="800">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">
            <Button Content="Save" Width="80" Margin="10" Click="Save_Click"/>
            <Button Content="Open" Width="80" Margin="10" Click="Load_Click"/>
            <Button Content="Clear" Click="Clear_Click" Width="80" Margin="10"/>
            <TextBlock Text="Brush Size:" VerticalAlignment="Center" Margin="10,10,0,10"/>
            <Slider Name ="BrushSlider" Minimum="1" Maximum="10" Value="2" Width="120" Margin="2,12,10,10"/>
            <TextBlock Text="Color:" VerticalAlignment="Center" Margin="10,10,0,10"/>
            <ComboBox Name="ColorPicker" Width="120" SelectedIndex="0" Margin="10">
                <ComboBoxItem Content="Black"/>
                <ComboBoxItem Content="Red"/>
                <ComboBoxItem Content="Blue"/>
                <ComboBoxItem Content="Green"/>
            </ComboBox>
        </StackPanel>
        <Canvas Name="DrawCanvas" Background="White" ClipToBounds="True" MouseDown="Canvas_MouseDown" MouseMove="Canvas_MouseMove" MouseUp="Canvas_MouseUp"/>
    </DockPanel>
</Window>

    
    