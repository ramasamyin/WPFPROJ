<Window x:Class="shapes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:shapes"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl>

            <!-- Circle Tab -->
            <TabItem Header="Circle">
                <StackPanel Margin="10">
                    
                    <TextBlock Foreground="Black" Text="Radius"/>
                    <TextBox x:Name="txtRadius"/>
                    <Button Content="Create" Click="CreateCircle_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Rectangle Tab -->
            <TabItem Header="Rectangle">
                <StackPanel Margin="10">
                    <TextBlock Foreground="Black" Text="Length"/>
                    <TextBox x:Name="txtLength" />
                    <TextBlock Foreground="Black" Text="Breadth"/>
                    <TextBox x:Name="txtBreadth" />
                    <Button Content="Create" Click="CreateRectangle_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Circle Tab -->
            <TabItem Header="Square">
                <StackPanel Margin="10">
                    <TextBlock Foreground="Black" Text="Side"/>
                    <TextBox x:Name="txtSide"/>
                    <Button Content="Create" Click="CreateSquare_Click"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
